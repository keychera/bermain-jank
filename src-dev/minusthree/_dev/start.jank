(ns minusthree.-dev.start
  (:require
   [minusthree.platform.sdl3.sdl3 :as sdl3]))

(defonce stop-atom (atom false))
(defonce refresh-atom (atom false))

(defn toggle-stop []
  (if (swap! stop-atom not)
    "stopping game..."
    "starting game..."))

(defn refresh []
  (reset! refresh-atom true)
  "refreshing game...")

(defn start []
  (let [dev-config (assoc {}
                          :stop-atom stop-atom
                          :refresh-atom refresh-atom)]
    (future
      (while true
        (when (not @stop-atom)
          (#'sdl3/start dev-config)
          (reset! stop-atom true))))))

(start)

(comment
  (toggle-stop)
  (refresh)

  ::waiting-for-something-to-happen?)